{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "codeward-waitlist",
  "compatibility_date": "2026-04-26",
  "main": "dist/_worker.js",
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "webapp-production",
      "database_id": "local-placeholder-id"
    }
  ]
}